---
// Aquí podrías añadir lógica si necesitas saber en qué página estás (active link)

// Configuración de WhatsApp con mensaje personalizado
const phone = "5491122334455";
const message = `¡Hola! ✨ Me gustaría recibir más información sobre el servicio uñas.`;
const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<nav class="sticky top-0 z-50 bg-white border-b border-slate-100">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a
        href="/"
        class="font-['Playfair_Display'] text-2xl tracking-tight text-slate-900"
      >
        Nail<span class="italic font-normal text-slate-500">Studio</span>
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center space-x-10 text-sm">
        <a
          href="https://dzhjose.github.io/portfolio-nails/"
          class="group relative text-slate-600 hover:text-slate-900 transition-colors"
        >
          Inicio
          <span
            class="absolute left-0 -bottom-1 w-0 h-[1px] bg-slate-900 transition-all duration-300 group-hover:w-full"
          ></span>
        </a>

        <a
          href="https://dzhjose.github.io/portfolio-nails/galeria"
          class="group relative text-slate-600 hover:text-slate-900 transition-colors"
        >
          Galería
          <span
            class="absolute left-0 -bottom-1 w-0 h-[1px] bg-slate-900 transition-all duration-300 group-hover:w-full"
          ></span>
        </a>

        <a
          href="https://dzhjose.github.io/portfolio-nails/servicios"
          class="group relative text-slate-600 hover:text-slate-900 transition-colors"
        >
          Servicios
          <span
            class="absolute left-0 -bottom-1 w-0 h-[1px] bg-slate-900 transition-all duration-300 group-hover:w-full"
          ></span>
        </a>

        <a
          href={whatsappUrl}
          class="ml-4 text-slate-900 font-semibold border-b border-slate-300 pb-1 hover:border-slate-900 transition-colors"
        >
          Agendar Cita
        </a>
      </div>

      <!-- Mobile button -->
      <div class="md:hidden">
        <button
          type="button"
          class="text-slate-700 p-2"
          id="mobile-menu-button"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    class="hidden md:hidden bg-white border-t border-slate-100"
    id="mobile-menu"
  >
    <div class="px-6 py-6 space-y-6 flex flex-col items-center text-sm">
      <a
        href="https://dzhjose.github.io/portfolio-nails/"
        class="text-slate-600 hover:text-slate-900 transition-colors">Inicio</a
      >
      <a
        href="https://dzhjose.github.io/portfolio-nails/galeria"
        class="text-slate-600 hover:text-slate-900 transition-colors">Galería</a
      >
      <a
        href="https://dzhjose.github.io/portfolio-nails/servicios"
        class="text-slate-600 hover:text-slate-900 transition-colors"
        >Servicios</a
      >
      <a
        href={whatsappUrl}
        class="font-semibold text-slate-900 border-b border-slate-300 pb-1"
      >
        Agendar Cita
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
