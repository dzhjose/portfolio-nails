---
import Footer from "../components/common/Footer.astro";
import Navbar from "../components/common/Navbar.astro";
import ScrollToTop from "../components/common/ScrollToTop.astro";
import WhatsAppButton from "../components/common/WhatsAppButton.astro";

import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Portfolio Profesional de Diseño de Uñas"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title} | NailArt Studio</title>
  </head>
  <body
    class="bg-white text-slate-900 font-['Inter'] antialiased flex flex-col min-h-screen"
  >
    <Navbar />

    <main class="grow">
      <slot />
    </main>

    <ScrollToTop />
    <WhatsAppButton />

    <Footer />
  </body>
</html>

<script type="module">
  import { initReveal } from "/src/scripts/reveal.js";

  const runReveal = () => {
    initReveal();
  };

  // Primera carga
  document.addEventListener("DOMContentLoaded", runReveal);

  // Navegaciones con View Transitions
  document.addEventListener("astro:page-load", runReveal);
</script>

<style is:global>
  /* Suavizamos el scroll para una mejor experiencia */
  html {
    scroll-behavior: smooth;
  }
  body {
    overflow-x: hidden;
  }
</style>
